# Copy to .env and fill in values. For Railway: set these in the Variables tab, not in .env.
# .env is gitignored and must never contain real secrets in the repo.

# ─── Required for app to run ─────────────────────────────────────────
DATABASE_URL=mysql://user:password@host:3306/database
JWT_SECRET=your-64-char-secret-use-openssl-rand-hex-32
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# ─── Railway: if MySQL is in same project, use private URL ──────────
# DATABASE_URL=mysql://root:YOUR_MYSQL_ROOT_PASSWORD@mysql.railway.internal:3306/railway

# ─── Optional: AI / LLM ─────────────────────────────────────────────
# BUILT_IN_FORGE_API_URL=https://api.openai.com/v1
# BUILT_IN_FORGE_API_KEY=sk-...
# VITE_FRONTEND_FORGE_API_URL=https://api.openai.com/v1
# VITE_FRONTEND_FORGE_API_KEY=sk-...

# ─── Optional: Stripe ────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# VITE_STRIPE_PUBLISHABLE_KEY=pk_...

# ─── Optional: Admin (get OWNER_OPEN_ID after first Google login) ────
# OWNER_OPEN_ID=google_123456789

# ─── Optional: Port (Railway sets PORT automatically) ───────────────
# PORT=3000

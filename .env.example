# ═══════════════════════════════════════════════════════════════
# OmniAI — Environment Variables
# Copy to .env for local dev. Set in Railway Variables for prod.
# ═══════════════════════════════════════════════════════════════

# ─── REQUIRED — App won't start without these ───────────────────
DATABASE_URL=mysql://root:password@localhost:3306/omni
JWT_SECRET=replace-with-output-of-openssl-rand-hex-32
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── REQUIRED — All AI features (Claude) ────────────────────────
ANTHROPIC_API_KEY=...

# ─── REQUIRED — Image generation ────────────────────────────────
# Point at any OpenAI-compatible image API
BUILT_IN_FORGE_API_URL=https://api.openai.com/v1
BUILT_IN_FORGE_API_KEY=sk-...

# ─── REQUIRED — Payments ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create in Stripe Dashboard)
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_BIZ_MONTHLY=price_...
STRIPE_PRICE_BIZ_ANNUAL=price_...
STRIPE_PRICE_AGENCY_MONTHLY=price_...
STRIPE_PRICE_AGENCY_ANNUAL=price_...

# Credit pack one-time Price IDs
STRIPE_PRICE_CREDITS_50=price_...
STRIPE_PRICE_CREDITS_150=price_...
STRIPE_PRICE_CREDITS_400=price_...
STRIPE_PRICE_CREDITS_1000=price_...
STRIPE_PRICE_CREDITS_5000=price_...

# ─── REQUIRED — Email sending ────────────────────────────────────
# Free tier: 100 emails/day, 3000/month — resend.com
RESEND_API_KEY=re_...

# ─── OPTIONAL — Voiceover ────────────────────────────────────────
ELEVENLABS_API_KEY=...
OPENAI_API_KEY=sk-...

# ─── OPTIONAL — Video generation (need at least one) ────────────
RUNWAY_API_KEY=...
LUMA_API_KEY=...
KLING_API_KEY=...

# ─── OPTIONAL — AI Avatars ───────────────────────────────────────
HEYGEN_API_KEY=...

# ─── OPTIONAL — Social media posting ────────────────────────────
META_APP_ID=...
META_APP_SECRET=...
TWITTER_API_KEY=...
TWITTER_API_SECRET=...
LINKEDIN_CLIENT_ID=...
LINKEDIN_CLIENT_SECRET=...
TIKTOK_CLIENT_KEY=...
TIKTOK_CLIENT_SECRET=...

# ─── OPTIONAL — E-commerce ───────────────────────────────────────
SHOPIFY_API_KEY=...
SHOPIFY_API_SECRET=...

# ─── OPTIONAL — Music generation ────────────────────────────────
SUNO_API_KEY=...
MUBERT_API_KEY=...
SOUNDRAW_API_KEY=...

# ─── OPTIONAL — App config ───────────────────────────────────────
# Your Railway URL — needed for correct file URLs + OAuth redirect
PUBLIC_URL=https://omniai-production-778d.up.railway.app
# Your user ID after first login (get from DB) → grants admin role
OWNER_OPEN_ID=google_...
# Error tracking
SENTRY_DSN=https://...@sentry.io/...

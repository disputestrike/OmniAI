# Copy to .env and fill in values. For Railway: set in Variables tab.
# Never commit .env or real secrets to git.
# Full reference: see API_KEYS.md

# ─── Required ─────────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@host:3306/database
# JWT_SECRET: required for login/session. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Set in Railway → OmniAI service → Variables. Never commit the real value.
JWT_SECRET=your-64-char-secret
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ─── Required for AI (Claude only — we do not use OpenAI/Forge) ─────
# Set in Railway → Variables. All text/strategy/agent features use Claude Haiku.
ANTHROPIC_API_KEY=sk-ant-...

# ─── Uploads (no Forge storage required) ──────────────────────────
# Local uploads dir (default ./uploads). On Railway, files are ephemeral unless you add a volume.
# UPLOAD_DIR=./uploads
# Full URL of your app for attachment links (e.g. https://yourapp.railway.app)
# PUBLIC_BASE_URL=https://yourapp.railway.app

# ─── Optional: image generation (only if you have an image service) ─
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=

# ─── Required for payments ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_...
# 7-day free trial for paid tiers (set TRIAL_DAYS=7)
TRIAL_DAYS=7
# Stripe Price IDs (create in Stripe Dashboard → Products → copy price_xxx)
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_BIZ_MONTHLY=price_...
STRIPE_PRICE_BIZ_ANNUAL=price_...
STRIPE_PRICE_AGENCY_MONTHLY=price_...
STRIPE_PRICE_AGENCY_ANNUAL=price_...
STRIPE_PRICE_CREDITS_50=price_...
STRIPE_PRICE_CREDITS_150=price_...
STRIPE_PRICE_CREDITS_400=price_...
STRIPE_PRICE_CREDITS_1000=price_...
STRIPE_PRICE_CREDITS_5000=price_...

# ─── Optional: admin panel ────────────────────────────────────────
# To access /admin and see the Admin item in the sidebar: set OWNER_OPEN_ID to your
# account's Open ID. Find it in Help → "Admin access & AI (Forge) setup" (copy button).
# Then redeploy and log out + log back in.
# OWNER_OPEN_ID=google_123456789
# PORT=3000

# ─── Optional: social publishing (code ready, add keys to activate) ─
# META_APP_ID=
# META_APP_SECRET=
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=

# ─── Optional: video generation ────────────────────────────────────
# RUNWAY_API_KEY=
# LUMA_API_KEY=
# KLING_API_KEY=

# ─── Optional: voice / voiceover ──────────────────────────────────
# ELEVENLABS_API_KEY=
# OPENAI_API_KEY=

# ─── Spec v4: Claude Haiku (strategy / analysis / scoring) ─────────
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Spec v4: Epom DSP (programmatic ad buying) ────────────────────
# Sign up at epom.com — White-Label DSP Light plan. Then add:
# EPOM_API_KEY=
# EPOM_BASE_URL=https://api.epom.com/v1
# EPOM_ACCOUNT_ID=
# DSP_ENABLED=true

# ─── Optional: AI avatars (HeyGen) ─────────────────────────────────
# HEYGEN_API_KEY=

# ─── Optional: e-commerce (Shopify) ─────────────────────────────────
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=

# ─── Optional: music studio ───────────────────────────────────────
# SUNO_API_KEY=
# MUBERT_API_KEY=
# SOUNDRAW_API_KEY=

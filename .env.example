# Copy to .env and fill in values. For Railway: set in Variables tab.
# Never commit .env or real secrets to git.
# Full reference: see API_KEYS.md

# ─── Required ─────────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@host:3306/database
# JWT_SECRET: required for login/session. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Set in Railway → OmniAI service → Variables. Never commit the real value.
JWT_SECRET=your-64-char-secret
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ─── Required for AI (content, images, transcription) ───────────────
# Without these, Content Studio and Creative Engine will show an error when generating.
BUILT_IN_FORGE_API_URL=https://api.openai.com/v1
BUILT_IN_FORGE_API_KEY=sk-...
# Optional: if you expose LLM to frontend
# VITE_FRONTEND_FORGE_API_URL=
# VITE_FRONTEND_FORGE_API_KEY=

# ─── Required for payments ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_...

# ─── Optional: admin panel ────────────────────────────────────────
# To access /admin and see the Admin item in the sidebar: set OWNER_OPEN_ID to your
# account's Open ID. Find it in Help → "Admin access & AI (Forge) setup" (copy button).
# Then redeploy and log out + log back in.
# OWNER_OPEN_ID=google_123456789
# PORT=3000

# ─── Optional: social publishing (code ready, add keys to activate) ─
# META_APP_ID=
# META_APP_SECRET=
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=

# ─── Optional: video generation ────────────────────────────────────
# RUNWAY_API_KEY=
# LUMA_API_KEY=
# KLING_API_KEY=

# ─── Optional: voice / voiceover ──────────────────────────────────
# ELEVENLABS_API_KEY=
# OPENAI_API_KEY=

# ─── Optional: AI avatars (HeyGen) ─────────────────────────────────
# HEYGEN_API_KEY=

# ─── Optional: e-commerce (Shopify) ─────────────────────────────────
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=

# ─── Optional: music studio ───────────────────────────────────────
# SUNO_API_KEY=
# MUBERT_API_KEY=
# SOUNDRAW_API_KEY=
